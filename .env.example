# Environment Configuration Example
# Copy this file to .env and fill in the actual values

# ===================================
# API Configuration
# ===================================
API_BASE_URL=http://localhost:3000/api
API_VERSION=v1
API_TIMEOUT=30

# ===================================
# OneSignal Push Notifications
# ===================================
# TODO: Add OneSignal App ID after creating account
ONESIGNAL_APP_ID=YOUR_ONESIGNAL_APP_ID_HERE

# ===================================
# Google Sign-In
# ===================================
# TODO: Obtain from Google Cloud Console
GOOGLE_CLIENT_ID_IOS=YOUR_GOOGLE_CLIENT_ID_IOS_HERE
GOOGLE_CLIENT_ID_ANDROID=YOUR_GOOGLE_CLIENT_ID_ANDROID_HERE
GOOGLE_CLIENT_ID_WEB=YOUR_GOOGLE_CLIENT_ID_WEB_HERE

# ===================================
# Apple Sign-In
# ===================================
# TODO: Obtain from Apple Developer Portal
APPLE_TEAM_ID=YOUR_APPLE_TEAM_ID_HERE
APPLE_CLIENT_ID=YOUR_APPLE_CLIENT_ID_HERE
APPLE_REDIRECT_URI=YOUR_APPLE_REDIRECT_URI_HERE

# ===================================
# Facebook Login
# ===================================
# TODO: Obtain from Facebook Developers Portal
FACEBOOK_APP_ID=YOUR_FACEBOOK_APP_ID_HERE
FACEBOOK_CLIENT_TOKEN=YOUR_FACEBOOK_CLIENT_TOKEN_HERE

# ===================================
# RevenueCat (After Store Approval)
# ===================================
# TODO: Add after store approval and RevenueCat setup
REVENUECAT_API_KEY_IOS=YOUR_REVENUECAT_IOS_KEY_HERE
REVENUECAT_API_KEY_ANDROID=YOUR_REVENUECAT_ANDROID_KEY_HERE

# ===================================
# App Configuration
# ===================================
APP_NAME=Lingola Travel
APP_VERSION=1.0.0

# Premium trial duration in days
PREMIUM_TRIAL_DAYS=1

# ===================================
# Feature Flags
# ===================================
ENABLE_FACEBOOK_LOGIN=false
ENABLE_REVENUECAT=false
ENABLE_ANALYTICS=true
ENABLE_CRASH_REPORTING=true

# ===================================
# Backend Configuration (for reference)
# ===================================
# These are backend environment variables
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=lingola_travel
# DB_USER=root
# DB_PASSWORD=your_password
# JWT_SECRET=your_jwt_secret
# JWT_REFRESH_SECRET=your_jwt_refresh_secret
# JWT_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d

# ===================================
# Notes
# ===================================
# 1. Never commit this file with real credentials
# 2. Keep .env in .gitignore
# 3. Update credentials before production deployment
# 4. For iOS, also update Info.plist with URL schemes
# 5. For Android, update AndroidManifest.xml with necessary keys
