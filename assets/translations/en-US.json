    "faq": {
        "faq_header": "F.A.Q.",
        "faq_section_general": "General",
        "faq_section_usage": "Usage",
        "faq_q1": "What is Lingola Travel?",
        "faq_a1": "Lingola Travel is a language learning app that practically teaches English words and phrases needed during travel.",
        "faq_q2": "Who is Lingola Travel for?",
        "faq_a2": "It is suitable for anyone going abroad, vacationing, or wanting to use English more comfortably during travel.",
        "faq_q3": "Does Lingola Travel teach general English?",
        "faq_a3": "No. Lingola Travel focuses on words and phrases specific to the most common travel situations.",
        "faq_q4": "What topics are covered?",
        "faq_a4": "It covers basic travel topics such as airport, hotel, restaurant, transportation, shopping, and emergencies.",
        "faq_q5": "Is it suitable for beginners?",
        "faq_a5": "Yes. Lingola Travel offers easy-to-understand content even for those just starting English.",
        "faq_q6": "How much time should I spend daily?",
        "faq_a6": "You can quickly learn words and phrases by spending just a few minutes a day.",
        "faq_q7": "How are the words taught?",
        "faq_a7": "Words are presented with short explanations and examples suitable for real travel scenarios.",
        "faq_q8": "Can it be used without an internet connection?",
        "faq_a8": "Some content can be used offline; an internet connection is recommended for the full experience.",
        "faq_q9": "Can I really use what I learn on a trip?",
        "faq_a9": "Yes. The content is prepared according to real-life usage cases needed during travel.",
        "faq_q10": "Is Lingola Travel free?",
        "faq_a10": "The app can be used for free; premium options may be offered for additional features and content."
    },
